# =============================================================================
# STOCKINI — Template de configuration
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS committer .env avec de vraies valeurs.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Stockini
NODE_ENV=development

# ─── Déploiement ─────────────────────────────────────────────────────────────
# En local : DEPLOYMENT_MODE=docker
# En production VPS : DEPLOYMENT_MODE=systemd
DEPLOYMENT_MODE=docker
BACKEND_SERVICE_NAME=stockini-backend
FRONTEND_SERVICE_NAME=stockini-frontend
POSTGRES_SERVICE_NAME=postgresql
REDIS_SERVICE_NAME=redis-server
NGINX_SERVICE_NAME=nginx
MINIO_SERVICE_NAME=minio

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=3001

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_TELEMETRY_DISABLED=1

# ─── Base de données (PostgreSQL) ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockpro
DB_USER=stockpro
DB_PASSWORD=
DATABASE_URL=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO (stockage des PDF générés) ────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=generated-documents
BACKUP_DIRECTORY=/opt/stockini/backups

# ─── SMTP (envoi d'emails) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Fournisseurs IA optionnels ──────────────────────────────────────────────
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ─── Informations société (PDF commerciaux) ───────────────────────────────────
COMPANY_NAME="Mon Entreprise"
COMPANY_ADDRESS=""
COMPANY_PHONE=""
COMPANY_EMAIL=""
COMPANY_TAX_ID=""
COMPANY_LOGO_URL=""
COMPANY_BANK_RIB=""

# ─── Seed (données initiales) ─────────────────────────────────────────────────
# Utilisé uniquement lors de l'exécution de : npx prisma db seed
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
