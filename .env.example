# =============================================================================
# STOCKINI — Template de configuration
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS committer .env avec de vraies valeurs.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Stockini
NODE_ENV=development

# ─── Déploiement ─────────────────────────────────────────────────────────────
# En local : DEPLOYMENT_MODE=docker
# En production VPS : DEPLOYMENT_MODE=systemd
DEPLOYMENT_MODE=docker
BACKEND_SERVICE_NAME=stockini-backend
FRONTEND_SERVICE_NAME=stockini-frontend
POSTGRES_SERVICE_NAME=postgresql
REDIS_SERVICE_NAME=redis-server
NGINX_SERVICE_NAME=nginx
MINIO_SERVICE_NAME=minio

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=3001

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_TELEMETRY_DISABLED=1

# ─── Base de données (PostgreSQL) ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockpro
DB_USER=stockpro
DB_PASSWORD=change_me_db_password
DATABASE_URL="postgresql://stockpro:change_me_db_password@localhost:5432/stockpro?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=change_me_jwt_secret_minimum_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO (stockage des PDF générés) ────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=change_me_minio_user
MINIO_SECRET_KEY=change_me_minio_password
MINIO_BUCKET=generated-documents

# ─── SMTP (envoi d'emails) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@email.com
SMTP_PASS=votre-mot-de-passe-application
SMTP_FROM=noreply@votreentreprise.com

# ─── Informations société (PDF commerciaux) ───────────────────────────────────
COMPANY_NAME="Mon Entreprise"
COMPANY_ADDRESS=""
COMPANY_PHONE=""
COMPANY_EMAIL=""
COMPANY_TAX_ID=""
COMPANY_LOGO_URL=""

# ─── Seed (données initiales) ─────────────────────────────────────────────────
# Utilisé uniquement lors de l'exécution de : npx prisma db seed
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me_admin_password
