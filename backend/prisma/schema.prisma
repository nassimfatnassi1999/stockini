generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CustomerType {
  INDIVIDUAL
  GARAGE
  COMPANY
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  SALE
  PURCHASE_RECEPTION
  CUSTOMER_RETURN
  SUPPLIER_RETURN
  INVENTORY_CORRECTION
  TRANSFER
}

enum CaisseMovementType {
  ENCAISSEMENT_VENTE
  DECAISSEMENT_ACHAT
  DEPOT_MANUEL
  RETRAIT_MANUEL
  ANNULATION_VENTE
  ANNULATION_ACHAT
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
  RETURNED
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  CHECK
  CREDIT
}

enum PaymentType {
  CUSTOMER_PAYMENT
  SUPPLIER_PAYMENT
  CREDIT_NOTE_REFUND
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  UNPAID_INVOICE
  PURCHASE_DELAY
  SYSTEM
}

enum DocumentType {
  DEVIS
  BON_COMMANDE
  BON_LIVRAISON
  FACTURE
  AVOIR
}

enum CreditNoteStatus {
  CREATED
  REFUNDED
  CANCELLED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum DocumentStatus {
  GENERATED
  SENT
  DELETED
}

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  passwordHash          String
  fullName              String
  roleId                String
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  role                  Role                  @relation(fields: [roleId], references: [id])
  stockMovements        StockMovement[]
  caisseMovements       CaisseMovement[]
  sales                 Sale[]                @relation("SellerSales")
  purchases             Purchase[]            @relation("CreatorPurchases")
  auditLogs             AuditLog[]
  generatedDocuments    GeneratedDocument[]
  documentEmailLogs     DocumentEmailLog[]
  creditNotes           CreditNote[]
  productPriceHistories ProductPriceHistory[]

  @@index([roleId])
}

model Role {
  id          String @id @default(cuid())
  name        String @unique
  permissions Json
  users       User[]
}

model Product {
  id                        String                @id @default(cuid())
  idProduct                 String                @unique
  reference                 String                @unique
  sku                       String                @unique
  barcode                   String?               @unique
  name                      String
  description               String?
  categoryId                String
  brandId                   String
  supplierId                String?
  tva                       Decimal               @default(19) @db.Decimal(5, 2)
  purchasePrice             Decimal               @db.Decimal(12, 3)
  purchasePriceTtc          Decimal               @default(0) @db.Decimal(12, 3)
  salePrice                 Decimal               @db.Decimal(12, 3)
  lastSellingPrice          Decimal?              @db.Decimal(12, 3)
  lastSaleDate              DateTime?
  lastSaleDocumentId        String?
  lastSaleDocumentReference String?
  lastSaleDocumentType      DocumentType?
  lastSaleCustomerId        String?
  quantity                  Int                   @default(0)
  minStock                  Int                   @default(0)
  location                  String?
  imageUrl                  String?
  isActive                  Boolean               @default(true)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  deletedAt                 DateTime?
  deletedBy                 String?
  category                  Category              @relation(fields: [categoryId], references: [id])
  brand                     Brand                 @relation(fields: [brandId], references: [id])
  supplier                  Supplier?             @relation(fields: [supplierId], references: [id])
  stockMovements            StockMovement[]
  saleItems                 SaleItem[]
  purchaseItems             PurchaseItem[]
  alerts                    Alert[]
  creditNoteItems           CreditNoteItem[]
  priceHistories            ProductPriceHistory[]
  lastSaleCustomer          Customer?             @relation("ProductLastSaleCustomer", fields: [lastSaleCustomerId], references: [id])

  @@index([categoryId])
  @@index([brandId])
  @@index([supplierId])
  @@index([lastSaleCustomerId])
  @@index([name])
  @@index([idProduct])
  @@index([reference])
  @@index([deletedAt])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  products    Product[]
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Customer {
  id                    String                @id @default(cuid())
  reference             String                @unique
  name                  String
  phone                 String?
  email                 String?
  address               String?
  type                  CustomerType          @default(INDIVIDUAL)
  taxNumber             String?
  creditBalance         Decimal               @default(0) @db.Decimal(12, 3)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?
  deletedBy             String?
  sales                 Sale[]
  payments              Payment[]
  creditNotes           CreditNote[]
  productLastSales      Product[]             @relation("ProductLastSaleCustomer")
  productPriceHistories ProductPriceHistory[]

  @@index([name])
  @@index([reference])
  @@index([deletedAt])
}

model Supplier {
  id            String     @id @default(cuid())
  reference     String     @unique
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  taxNumber     String?
  paymentTerms  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
  deletedBy     String?
  products      Product[]
  purchases     Purchase[]
  payments      Payment[]

  @@index([name])
  @@index([reference])
  @@index([deletedAt])
}

model StockMovement {
  id               String            @id @default(cuid())
  productId        String
  type             StockMovementType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  reference        String?           @unique
  userId           String?
  createdAt        DateTime          @default(now())
  product          Product           @relation(fields: [productId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

model Sale {
  id                      String                @id @default(cuid())
  invoiceNumber           String                @unique
  customerId              String?
  subtotal                Decimal               @db.Decimal(12, 3)
  discount                Decimal               @default(0) @db.Decimal(12, 3)
  tax                     Decimal               @default(0) @db.Decimal(12, 3)
  total                   Decimal               @db.Decimal(12, 3)
  paidAmount              Decimal               @default(0) @db.Decimal(12, 3)
  remainingAmount         Decimal               @default(0) @db.Decimal(12, 3)
  paymentStatus           PaymentStatus         @default(UNPAID)
  status                  SaleStatus            @default(DRAFT)
  documentType            DocumentType          @default(DEVIS)
  stockImpactDone         Boolean               @default(false)
  lastSalePriceImpactDone Boolean               @default(false) @map("last_sale_price_impact_done")
  reserveStock            Boolean               @default(false)
  sellerId                String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  deletedAt               DateTime?
  deletedBy               String?
  customer                Customer?             @relation(fields: [customerId], references: [id])
  seller                  User?                 @relation("SellerSales", fields: [sellerId], references: [id])
  items                   SaleItem[]
  payments                Payment[]
  generatedDocuments      GeneratedDocument[]
  creditNotes             CreditNote[]
  productPriceHistories   ProductPriceHistory[]

  @@index([customerId])
  @@index([sellerId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([documentType, status, createdAt])
}

model SaleItem {
  id              String           @id @default(cuid())
  saleId          String
  productId       String
  quantity        Int
  unitPrice       Decimal          @db.Decimal(12, 3)
  discountPercent Decimal          @default(0) @db.Decimal(5, 2)
  finalUnitPrice  Decimal?         @db.Decimal(12, 3)
  total           Decimal          @db.Decimal(12, 3)
  sale            Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id])
  creditNoteItems CreditNoteItem[]

  @@index([saleId])
  @@index([productId])
}

model ProductPriceHistory {
  id                String       @id @default(cuid())
  productId         String       @map("product_id")
  documentId        String       @map("document_id")
  documentType      DocumentType @map("document_type")
  documentReference String       @map("document_reference")
  clientId          String?      @map("client_id")
  prixVente         Decimal      @map("prix_vente") @db.Decimal(12, 3)
  dateVente         DateTime     @map("date_vente")
  userId            String?      @map("user_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  product           Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  document          Sale         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  client            Customer?    @relation(fields: [clientId], references: [id])
  user              User?        @relation(fields: [userId], references: [id])

  @@unique([productId, documentId])
  @@index([productId, dateVente])
  @@index([documentId])
  @@index([clientId])
  @@index([userId])
  @@map("product_price_history")
}

model Purchase {
  id              String         @id @default(cuid())
  orderNumber     String         @unique
  supplierId      String
  subtotal        Decimal        @db.Decimal(12, 3)
  discount        Decimal        @default(0) @db.Decimal(12, 3)
  tax             Decimal        @default(0) @db.Decimal(12, 3)
  total           Decimal        @db.Decimal(12, 3)
  paidAmount      Decimal        @default(0) @db.Decimal(12, 3)
  remainingAmount Decimal        @default(0) @db.Decimal(12, 3)
  paymentStatus   PaymentStatus  @default(UNPAID)
  status          PurchaseStatus @default(DRAFT)
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  deletedBy       String?
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  createdBy       User?          @relation("CreatorPurchases", fields: [createdById], references: [id])
  items           PurchaseItem[]
  payments        Payment[]

  @@index([supplierId])
  @@index([createdById])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([status, createdAt])
}

model PurchaseItem {
  id               String   @id @default(cuid())
  purchaseId       String
  productId        String
  quantity         Int
  receivedQuantity Int      @default(0)
  unitCost         Decimal  @db.Decimal(12, 3)
  total            Decimal  @db.Decimal(12, 3)
  purchase         Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}

model Payment {
  id             String        @id @default(cuid())
  reference      String        @unique
  type           PaymentType
  method         PaymentMethod
  amount         Decimal       @db.Decimal(12, 3)
  cashImpactDone Boolean       @default(false)
  saleId         String?
  purchaseId     String?
  customerId     String?
  supplierId     String?
  creditNoteId   String?
  note           String?
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?
  deletedBy      String?
  sale           Sale?         @relation(fields: [saleId], references: [id])
  purchase       Purchase?     @relation(fields: [purchaseId], references: [id])
  customer       Customer?     @relation(fields: [customerId], references: [id])
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
  creditNote     CreditNote?   @relation(fields: [creditNoteId], references: [id])

  @@index([saleId])
  @@index([purchaseId])
  @@index([customerId])
  @@index([supplierId])
  @@index([creditNoteId])
  @@index([createdAt])
  @@index([reference])
  @@index([deletedAt])
}

model Alert {
  id           String    @id @default(cuid())
  type         AlertType
  title        String
  message      String
  productId    String?
  designation  String?
  reference    String?
  currentStock Int?      @map("current_stock")
  minimumStock Int?      @map("minimum_stock")
  isRead       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  product      Product?  @relation(fields: [productId], references: [id])

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([productId])
}

model GeneratedDocument {
  id             String             @id @default(cuid())
  invoiceId      String?
  creditNoteId   String?
  clientId       String?
  clientName     String?
  documentType   DocumentType
  documentNumber String             @unique
  fileName       String
  minioBucket    String
  minioObjectKey String
  fileSize       Int?
  mimeType       String             @default("application/pdf")
  totalHt        Decimal?           @db.Decimal(12, 3)
  totalTva       Decimal?           @db.Decimal(12, 3)
  totalTtc       Decimal?           @db.Decimal(12, 3)
  generatedBy    String?
  generatedAt    DateTime           @default(now())
  status         DocumentStatus     @default(GENERATED)
  deletedAt      DateTime?
  emailStatus    EmailStatus        @default(PENDING)
  sentAt         DateTime?
  sentTo         String?
  sale           Sale?              @relation(fields: [invoiceId], references: [id])
  creditNote     CreditNote?        @relation(fields: [creditNoteId], references: [id])
  generator      User?              @relation(fields: [generatedBy], references: [id])
  emailLogs      DocumentEmailLog[]

  @@index([invoiceId])
  @@index([creditNoteId])
  @@index([clientId])
  @@index([generatedAt])
  @@index([emailStatus])
  @@index([status])
  @@index([deletedAt])
}

model DocumentEmailLog {
  id             String            @id @default(cuid())
  documentId     String
  recipientEmail String
  cc             String?
  bcc            String?
  subject        String
  message        String?
  sentAt         DateTime          @default(now())
  sentBy         String?
  status         EmailStatus
  errorMessage   String?
  createdAt      DateTime          @default(now())
  document       GeneratedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sentByUser     User?             @relation(fields: [sentBy], references: [id])

  @@index([documentId])
  @@index([sentAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReferenceCounter {
  id        String   @id @default(cuid())
  prefix    String
  year      Int
  sequence  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([prefix, year], name: "prefix_year")
  @@index([prefix, year])
}

model DropdownOption {
  id        String   @id @default(cuid())
  category  String
  label     String
  value     String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, value], name: "category_value")
  @@index([category, active, sortOrder])
}

model CreditNote {
  id               String              @id @default(cuid())
  numero           String              @unique
  saleId           String
  customerId       String?
  dateAvoir        DateTime            @default(now())
  subtotal         Decimal             @db.Decimal(12, 3)
  tax              Decimal             @default(0) @db.Decimal(12, 3)
  total            Decimal             @db.Decimal(12, 3)
  montantRembourse Decimal             @db.Decimal(12, 3)
  motif            String?
  statut           CreditNoteStatus    @default(CREATED)
  createdById      String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  sale             Sale                @relation(fields: [saleId], references: [id])
  customer         Customer?           @relation(fields: [customerId], references: [id])
  createdBy        User?               @relation(fields: [createdById], references: [id])
  items            CreditNoteItem[]
  payments         Payment[]
  documents        GeneratedDocument[]

  @@index([saleId])
  @@index([customerId])
  @@index([createdById])
  @@index([createdAt])
}

model CreditNoteItem {
  id                String     @id @default(cuid())
  creditNoteId      String
  saleItemId        String?
  productId         String
  designation       String
  quantiteRetournee Int
  prixUnitaireHt    Decimal    @db.Decimal(12, 3)
  tva               Decimal    @default(19) @db.Decimal(5, 2)
  totalHt           Decimal    @db.Decimal(12, 3)
  totalTtc          Decimal    @db.Decimal(12, 3)
  motifLigne        String?
  creditNote        CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  product           Product    @relation(fields: [productId], references: [id])
  saleItem          SaleItem?  @relation(fields: [saleItemId], references: [id])

  @@index([creditNoteId])
  @@index([productId])
  @@index([saleItemId])
}

model CaisseMovement {
  id           String             @id @default(cuid())
  type         CaisseMovementType
  montant      Decimal            @db.Decimal(12, 3)
  ancienSolde  Decimal            @db.Decimal(12, 3)
  nouveauSolde Decimal            @db.Decimal(12, 3)
  motif        String?
  referenceDoc String?
  userId       String?
  createdAt    DateTime           @default(now())
  user         User?              @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([createdAt])
  @@index([userId])
  @@index([type, createdAt])
}

model CaisseConfig {
  id            String   @id @default(cuid())
  solde         Decimal  @default(0) @db.Decimal(12, 3)
  allowNegative Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}
