generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CustomerType {
  INDIVIDUAL
  GARAGE
  COMPANY
}

enum CustomerOrigin {
  MANUAL
  SALE_COUNTER
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  SALE
  PURCHASE_RECEPTION
  CUSTOMER_RETURN
  SUPPLIER_RETURN
  INVENTORY_CORRECTION
  TRANSFER
}

enum CaisseMovementType {
  ENCAISSEMENT_VENTE
  DECAISSEMENT_ACHAT
  DEPENSE_GENERALE
  DEPOT_MANUEL
  RETRAIT_MANUEL
  ANNULATION_VENTE
  ANNULATION_ACHAT
  ANNULATION_DEPENSE
  CASH_RESET
}

enum CashDirection {
  IN
  OUT
}

enum TreasuryAccount {
  PHYSICAL_CASH
  BANK_TREASURY
}

enum CashTransactionType {
  SALE
  PURCHASE
  PAYMENT
  EXPENSE
  CREDIT_NOTE
  MANUAL
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
  RETURNED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PurchaseDocumentType {
  BON_COMMANDE
  BON_RECEPTION
  FACTURE_FOURNISSEUR
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  CHECK
  CREDIT
}

enum PaymentType {
  CUSTOMER_PAYMENT
  SUPPLIER_PAYMENT
  CREDIT_NOTE_REFUND
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  UNPAID_INVOICE
  PURCHASE_DELAY
  SYSTEM
}

enum DocumentType {
  DEVIS
  BON_COMMANDE
  BON_LIVRAISON
  FACTURE
  AVOIR
}

enum CreditNoteStatus {
  CREATED
  REFUNDED
  CANCELLED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum DocumentStatus {
  GENERATED
  SENT
  DELETED
}

enum ExpenseStatus {
  ACTIVE
  CANCELLED
}

enum PermissionEffect {
  ALLOW
  DENY
}

model UserPermission {
  id             String           @id @default(cuid())
  userId         String
  permissionCode String
  effect         PermissionEffect
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionCode])
  @@index([userId])
}

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  passwordHash          String
  fullName              String
  phone                 String?
  roleId                String
  isActive              Boolean               @default(true)
  lastLoginAt           DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  role                  Role                  @relation(fields: [roleId], references: [id])
  userPermissions       UserPermission[]
  stockMovements        StockMovement[]
  caisseMovements       CaisseMovement[]
  cashTransactions      CashTransaction[]
  expenses              Expense[]
  sales                 Sale[]                @relation("SellerSales")
  purchases             Purchase[]            @relation("CreatorPurchases")
  auditLogs             AuditLog[]
  generatedDocuments    GeneratedDocument[]
  documentEmailLogs     DocumentEmailLog[]
  creditNotes           CreditNote[]
  productPriceHistories ProductPriceHistory[]
  historyClearLogs      HistoryClearLog[]

  @@index([roleId])
}

model Role {
  id          String @id @default(cuid())
  name        String @unique
  permissions Json
  users       User[]
}

model Product {
  id                        String                @id @default(cuid())
  idProduct                 String                @unique
  reference                 String                @unique
  sku                       String                @unique
  barcode                   String?               @unique
  name                      String
  description               String?
  categoryId                String
  brandId                   String
  supplierId                String?
  tva                       Decimal               @default(19) @db.Decimal(5, 2)
  purchasePrice             Decimal               @db.Decimal(12, 3)
  purchasePriceTtc          Decimal               @default(0) @db.Decimal(12, 3)
  salePrice                 Decimal               @db.Decimal(12, 3)
  lastSellingPrice          Decimal?              @db.Decimal(12, 3)
  lastSaleDate              DateTime?
  lastSaleDocumentId        String?
  lastSaleDocumentReference String?
  lastSaleDocumentType      DocumentType?
  lastSaleCustomerId        String?
  quantity                  Int                   @default(0)
  minStock                  Int                   @default(0)
  location                  String?
  imageUrl                  String?
  isActive                  Boolean               @default(true)
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  deletedAt                 DateTime?
  deletedBy                 String?
  category                  Category              @relation(fields: [categoryId], references: [id])
  brand                     Brand                 @relation(fields: [brandId], references: [id])
  supplier                  Supplier?             @relation(fields: [supplierId], references: [id])
  stockMovements            StockMovement[]
  saleItems                 SaleItem[]
  purchaseItems             PurchaseItem[]
  alerts                    Alert[]
  creditNoteItems           CreditNoteItem[]
  priceHistories            ProductPriceHistory[]
  lastSaleCustomer          Customer?             @relation("ProductLastSaleCustomer", fields: [lastSaleCustomerId], references: [id])

  @@index([categoryId])
  @@index([brandId])
  @@index([supplierId])
  @@index([lastSaleCustomerId])
  @@index([name])
  @@index([idProduct])
  @@index([reference])
  @@index([deletedAt])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  products    Product[]
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Customer {
  id                    String                @id @default(cuid())
  reference             String                @unique
  name                  String
  phone                 String?
  email                 String?
  address               String?
  type                  CustomerType          @default(INDIVIDUAL)
  origin                CustomerOrigin        @default(MANUAL)
  taxNumber             String?
  creditBalance         Decimal               @default(0) @db.Decimal(12, 3)
  isLocked              Boolean               @default(false)
  lockedAt              DateTime?
  lockedReason          String?
  lockedByUserId        String?
  debtDueDate           DateTime?
  autoLockEnabled       Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?
  deletedBy             String?
  sales                 Sale[]
  payments              Payment[]
  creditNotes           CreditNote[]
  productLastSales      Product[]             @relation("ProductLastSaleCustomer")
  productPriceHistories ProductPriceHistory[]

  @@index([name])
  @@index([reference])
  @@index([deletedAt])
  @@index([isLocked])
}

model Supplier {
  id            String     @id @default(cuid())
  reference     String     @unique
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  taxNumber     String?
  paymentTerms  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
  deletedBy     String?
  products      Product[]
  purchases     Purchase[]
  payments      Payment[]
  expenses      Expense[]

  @@index([name])
  @@index([reference])
  @@index([deletedAt])
}

model StockMovement {
  id               String            @id @default(cuid())
  productId        String
  type             StockMovementType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  reference        String?           @unique
  userId           String?
  createdAt        DateTime          @default(now())
  product          Product           @relation(fields: [productId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

model Sale {
  id                      String                @id @default(cuid())
  invoiceNumber           String                @unique
  customerId              String?
  subtotal                Decimal               @db.Decimal(12, 3)
  discount                Decimal               @default(0) @db.Decimal(12, 3)
  tax                     Decimal               @default(0) @db.Decimal(12, 3)
  total                   Decimal               @db.Decimal(12, 3)
  stampDuty               Decimal               @default(1) @db.Decimal(12, 3)
  paidAmount              Decimal               @default(0) @db.Decimal(12, 3)
  remainingAmount         Decimal               @default(0) @db.Decimal(12, 3)
  totalRefunded           Decimal               @default(0) @db.Decimal(12, 3)
  totalInitialTtc         Decimal?              @db.Decimal(12, 3)
  totalCurrentTtc         Decimal?              @db.Decimal(12, 3)
  paymentStatus           PaymentStatus?
  status                  SaleStatus            @default(DRAFT)
  documentType            DocumentType          @default(DEVIS)
  stockImpactDone         Boolean               @default(false)
  lastSalePriceImpactDone Boolean               @default(false) @map("last_sale_price_impact_done")
  reserveStock            Boolean               @default(false)
  sourceDocumentId        String?               @map("source_document_id")
  transformedToId         String?               @map("transformed_to_id")
  sellerId                String?
  clientType              String?               @map("client_type")
  counterClientFirstName  String?               @map("counter_client_first_name")
  counterClientLastName   String?               @map("counter_client_last_name")
  counterClientFullName   String?               @map("counter_client_full_name")
  counterClientPhone      String?               @map("counter_client_phone")
  counterClientAddress    String?               @map("counter_client_address")
  counterClientEmail      String?               @map("counter_client_email")
  counterClientTaxId      String?               @map("counter_client_tax_id")
  counterClientNote       String?               @map("counter_client_note")
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  isEdited                Boolean               @default(false)
  editedAt                DateTime?
  deletedAt               DateTime?
  deletedBy               String?
  customer                Customer?             @relation(fields: [customerId], references: [id])
  seller                  User?                 @relation("SellerSales", fields: [sellerId], references: [id])
  items                   SaleItem[]
  payments                Payment[]
  generatedDocuments      GeneratedDocument[]
  creditNotes             CreditNote[]
  productPriceHistories   ProductPriceHistory[]

  @@index([customerId])
  @@index([sellerId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([documentType, status, createdAt])
}

model SaleItem {
  id              String           @id @default(cuid())
  saleId          String
  productId       String
  designation     String?
  quantity        Int
  unitPrice       Decimal          @db.Decimal(12, 3)
  discountPercent Decimal          @default(0) @db.Decimal(5, 2)
  marginPercent   Decimal?         @db.Decimal(7, 3)
  tvaPercent      Decimal?         @db.Decimal(5, 2)
  finalUnitPrice  Decimal?         @db.Decimal(12, 3)
  total           Decimal          @db.Decimal(12, 3)
  unitPurchaseCostHt Decimal?       @map("unit_purchase_cost_ht") @db.Decimal(12, 3)
  purchaseCostEstimated Boolean    @default(false) @map("purchase_cost_estimated")
  calculationVersion Int           @default(1) @map("calculation_version")
  sale            Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id])
  creditNoteItems CreditNoteItem[]

  @@index([saleId])
  @@index([productId])
}

model ProductPriceHistory {
  id                String       @id @default(cuid())
  productId         String       @map("product_id")
  documentId        String       @map("document_id")
  documentType      DocumentType @map("document_type")
  documentReference String       @map("document_reference")
  clientId          String?      @map("client_id")
  prixVente         Decimal      @map("prix_vente") @db.Decimal(12, 3)
  dateVente         DateTime     @map("date_vente")
  userId            String?      @map("user_id")
  createdAt         DateTime     @default(now()) @map("created_at")
  product           Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  document          Sale         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  client            Customer?    @relation(fields: [clientId], references: [id])
  user              User?        @relation(fields: [userId], references: [id])

  @@unique([productId, documentId])
  @@index([productId, dateVente])
  @@index([documentId])
  @@index([clientId])
  @@index([userId])
  @@map("product_price_history")
}

model Purchase {
  id              String         @id @default(cuid())
  orderNumber     String         @unique
  supplierId      String
  subtotal        Decimal        @db.Decimal(12, 3)
  discount        Decimal        @default(0) @db.Decimal(12, 3)
  tax             Decimal        @default(0) @db.Decimal(12, 3)
  total           Decimal        @db.Decimal(12, 3)
  stampDuty       Decimal        @default(1) @db.Decimal(12, 3)
  supplierReference          String?
  paidAmount      Decimal        @default(0) @db.Decimal(12, 3)
  remainingAmount Decimal        @default(0) @db.Decimal(12, 3)
  paymentStatus   PaymentStatus        @default(UNPAID)
  status          PurchaseStatus       @default(DRAFT)
  documentType    PurchaseDocumentType @default(BON_COMMANDE) @map("document_type")
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  isEdited        Boolean        @default(false)
  editedAt        DateTime?
  deletedAt       DateTime?
  deletedBy       String?
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  createdBy       User?          @relation("CreatorPurchases", fields: [createdById], references: [id])
  items           PurchaseItem[]
  payments        Payment[]
  expenses        Expense[]

  @@index([supplierId])
  @@index([createdById])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([status, createdAt])
  @@index([documentType, paymentStatus])
  @@index([supplierReference])
}

model PurchaseItem {
  id               String   @id @default(cuid())
  purchaseId       String
  productId        String
  designation      String?
  quantity         Int
  receivedQuantity Int      @default(0)
  unitCost         Decimal  @db.Decimal(12, 3)
  discountPercent  Decimal  @default(0) @db.Decimal(5, 2)
  tvaPercent       Decimal? @db.Decimal(5, 2)
  total            Decimal  @db.Decimal(12, 3)
  purchase         Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}

model Payment {
  id             String        @id @default(cuid())
  reference      String        @unique
  type           PaymentType
  method         PaymentMethod
  amount         Decimal       @db.Decimal(12, 3)
  cashImpactDone Boolean       @default(false)
  saleId         String?
  purchaseId     String?
  customerId     String?
  supplierId     String?
  creditNoteId   String?
  note           String?
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?
  deletedBy      String?
  clearedAt      DateTime?
  clearedBy      String?
  sale           Sale?         @relation(fields: [saleId], references: [id])
  purchase       Purchase?     @relation(fields: [purchaseId], references: [id])
  customer       Customer?     @relation(fields: [customerId], references: [id])
  supplier       Supplier?     @relation(fields: [supplierId], references: [id])
  creditNote     CreditNote?   @relation(fields: [creditNoteId], references: [id])

  @@index([saleId])
  @@index([purchaseId])
  @@index([customerId])
  @@index([supplierId])
  @@index([creditNoteId])
  @@index([createdAt])
  @@index([reference])
  @@index([deletedAt])
}

model Expense {
  id              String          @id @default(cuid())
  reference       String          @unique
  amount          Decimal         @db.Decimal(12, 3)
  paymentSource   TreasuryAccount
  category        String
  expenseDate     DateTime
  description     String
  supplierId      String?
  purchaseId      String?
  attachmentUrl   String?
  status          ExpenseStatus   @default(ACTIVE)
  createdById     String?
  cancelledAt     DateTime?
  cancelledById   String?
  cancelReason    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])
  purchase        Purchase?       @relation(fields: [purchaseId], references: [id])
  createdBy       User?           @relation(fields: [createdById], references: [id])
  caisseMovements CaisseMovement[]

  @@index([paymentSource])
  @@index([category])
  @@index([expenseDate])
  @@index([supplierId])
  @@index([purchaseId])
  @@index([status])
  @@index([createdById])
}

model Alert {
  id           String    @id @default(cuid())
  type         AlertType
  title        String
  message      String
  productId    String?
  designation  String?
  reference    String?
  currentStock Int?      @map("current_stock")
  minimumStock Int?      @map("minimum_stock")
  isRead       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  product      Product?  @relation(fields: [productId], references: [id])

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([productId])
}

model GeneratedDocument {
  id             String             @id @default(cuid())
  invoiceId      String?
  creditNoteId   String?
  clientId       String?
  clientName     String?
  documentType   DocumentType
  documentNumber String             @unique
  fileName       String
  minioBucket    String
  minioObjectKey String
  fileSize       Int?
  mimeType       String             @default("application/pdf")
  totalHt        Decimal?           @db.Decimal(12, 3)
  totalTva       Decimal?           @db.Decimal(12, 3)
  totalTtc       Decimal?           @db.Decimal(12, 3)
  stampDuty      Decimal            @default(1) @db.Decimal(12, 3)
  totalFinal     Decimal?           @db.Decimal(12, 3)
  generatedBy    String?
  generatedAt    DateTime           @default(now())
  status         DocumentStatus     @default(GENERATED)
  deletedAt      DateTime?
  deletedBy      String?
  emailStatus    EmailStatus        @default(PENDING)
  sentAt         DateTime?
  sentTo         String?
  sale           Sale?              @relation(fields: [invoiceId], references: [id])
  creditNote     CreditNote?        @relation(fields: [creditNoteId], references: [id])
  generator      User?              @relation(fields: [generatedBy], references: [id])
  emailLogs      DocumentEmailLog[]

  @@index([invoiceId])
  @@index([creditNoteId])
  @@index([clientId])
  @@index([generatedAt])
  @@index([emailStatus])
  @@index([status])
  @@index([deletedAt])
}

model DocumentEmailLog {
  id             String            @id @default(cuid())
  documentId     String
  recipientEmail String
  cc             String?
  bcc            String?
  subject        String
  message        String?
  sentAt         DateTime          @default(now())
  sentBy         String?
  status         EmailStatus
  errorMessage   String?
  createdAt      DateTime          @default(now())
  document       GeneratedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sentByUser     User?             @relation(fields: [sentBy], references: [id])

  @@index([documentId])
  @@index([sentAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  userName  String?
  oldValue  Json?
  newValue  Json?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([entityId])
  @@index([createdAt])
}

model AuditLogArchive {
  id         String   @id
  action     String
  entity     String
  entityId   String?
  userId     String?
  userName   String?
  oldValue   Json?
  newValue   Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime
  archivedAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@map("audit_log_archives")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReferenceCounter {
  id        String   @id @default(cuid())
  prefix    String
  year      Int
  sequence  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([prefix, year], name: "prefix_year")
  @@index([prefix, year])
}

model DropdownOption {
  id        String   @id @default(cuid())
  category  String
  label     String
  value     String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, value], name: "category_value")
  @@index([category, active, sortOrder])
}

model CreditNote {
  id               String              @id @default(cuid())
  numero           String              @unique
  saleId           String
  customerId       String?
  dateAvoir        DateTime            @default(now())
  subtotal         Decimal             @db.Decimal(12, 3)
  tax              Decimal             @default(0) @db.Decimal(12, 3)
  total            Decimal             @db.Decimal(12, 3)
  stampDuty        Decimal             @default(1) @db.Decimal(12, 3)
  montantRembourse Decimal             @db.Decimal(12, 3)
  motif            String?
  statut           CreditNoteStatus    @default(CREATED)
  createdById      String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  sale             Sale                @relation(fields: [saleId], references: [id])
  customer         Customer?           @relation(fields: [customerId], references: [id])
  createdBy        User?               @relation(fields: [createdById], references: [id])
  items            CreditNoteItem[]
  payments         Payment[]
  documents        GeneratedDocument[]

  @@index([saleId])
  @@index([customerId])
  @@index([createdById])
  @@index([createdAt])
}

model CreditNoteItem {
  id                String     @id @default(cuid())
  creditNoteId      String
  saleItemId        String?
  productId         String
  designation       String
  quantiteRetournee Int
  prixUnitaireHt    Decimal    @db.Decimal(12, 3)
  tva               Decimal    @default(19) @db.Decimal(5, 2)
  totalHt           Decimal    @db.Decimal(12, 3)
  totalTtc          Decimal    @db.Decimal(12, 3)
  motifLigne        String?
  stockRestocked    Boolean    @default(true) @map("stock_restocked")
  creditNote        CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  product           Product    @relation(fields: [productId], references: [id])
  saleItem          SaleItem?  @relation(fields: [saleItemId], references: [id])

  @@index([creditNoteId])
  @@index([productId])
  @@index([saleItemId])
}

model CaisseMovement {
  id              String             @id @default(cuid())
  type            CaisseMovementType
  treasuryAccount TreasuryAccount    @default(PHYSICAL_CASH)
  montant         Decimal            @db.Decimal(12, 3)
  ancienSolde     Decimal            @db.Decimal(12, 3)
  nouveauSolde    Decimal            @db.Decimal(12, 3)
  motif           String?
  referenceDoc    String?
  expenseId       String?
  userId          String?
  createdAt       DateTime           @default(now())
  clearedAt       DateTime?
  clearedBy       String?
  user            User?              @relation(fields: [userId], references: [id])
  expense         Expense?           @relation(fields: [expenseId], references: [id])

  @@index([type])
  @@index([treasuryAccount])
  @@index([createdAt])
  @@index([userId])
  @@index([expenseId])
  @@index([type, createdAt])
  @@index([treasuryAccount, createdAt])
}

model CaisseConfig {
  id                  String   @id @default(cuid())
  solde               Decimal  @default(0) @db.Decimal(12, 3)
  soldeBanque         Decimal  @default(0) @db.Decimal(12, 3)
  allowNegative       Boolean  @default(false)
  allowNegativeBanque Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model HistoryClearLog {
  id         String   @id @default(cuid())
  module     String
  userId     String?
  count      Int
  clearedAt  DateTime @default(now())
  filtersJson Json?
  user       User?    @relation(fields: [userId], references: [id])

  @@index([module])
  @@index([clearedAt])
  @@index([userId])
  @@map("history_clear_logs")
}

model CashTransaction {
  id            String              @id @default(cuid())
  type          CashTransactionType
  amount        Decimal             @db.Decimal(12, 3)
  direction     CashDirection
  sourceType    String
  sourceId      String?
  reference     String?
  description   String?
  paymentMethod String?
  createdAt     DateTime            @default(now())
  createdById   String?
  createdBy     User?               @relation(fields: [createdById], references: [id])

  @@index([type])
  @@index([direction])
  @@index([createdAt])
